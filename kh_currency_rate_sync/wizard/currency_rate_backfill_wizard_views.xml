<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_currency_rate_backfill_wizard_form" model="ir.ui.view">
        <field name="name">currency.rate.backfill.wizard.form</field>
        <field name="model">currency.rate.backfill.wizard</field>
        <field name="arch" type="xml">
            <form string="Backfill Currency Rates">
                <group>
                    <field name="company_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="currency_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_backfill_rates" type="object" string="Backfill" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_currency_rate_backfill_wizard" model="ir.actions.act_window">
        <field name="name">Backfill Currency Rates</field>
        <field name="res_model">currency.rate.backfill.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_currency_rate_backfill_wizard"
        name="Backfill Currency Rates"
        parent="account.menu_finance_configuration"
        action="action_currency_rate_backfill_wizard"
        groups="account.group_account_manager"
        sequence="95"
    />
</odoo>
